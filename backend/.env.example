# Postgres connection string from Supabase (Session pooler).
# Special characters in the password must be URL-encoded (@ becomes %40).
DATABASE_URL=postgresql://postgres.your-project:your-password@aws-0-region.pooler.supabase.com:5432/postgres

# Read-only user for AI-generated SQL (see database/readonly_role.sql)
READONLY_DATABASE_URL=postgresql://wfx_readonly.your-project:role-password@aws-0-region.pooler.supabase.com:5432/postgres

# OpenRouter - LLM access for the NL-to-SQL feature
OPENROUTER_API_KEY=sk-or-v1-your-key
OPENROUTER_MODEL=openai/gpt-4o-mini

# Typesense Cloud - product search
TYPESENSE_HOST=your-cluster.a1.typesense.net
TYPESENSE_API_KEY=your-admin-api-key

# Secret token for POST /api/search/reindex (choose any random string)
REINDEX_TOKEN=some-random-secret
